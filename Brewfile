# 依存パッケージの宣言。`brew bundle --file=Brewfile` で一括インストール。

# --- CLI ツール ---
brew "neovim"     # エディタ
brew "tmux"       # ターミナルマルチプレクサ
brew "ghq"        # リポジトリ管理（git clone のラッパ）
brew "fzf"        # 曖昧検索
brew "ripgrep"    # 高速 grep（telescope live_grep が使用）
brew "fd"         # 高速 find（telescope find_files が使用）
brew "starship"   # プロンプト
brew "mise"       # ランタイム管理（Go / Node など。nvim が PATH に追加）
brew "git"

# --- GUI / フォント ---
cask "ghostty"                       # ターミナルエミュレータ
cask "font-jetbrains-mono-nerd-font" # 等幅 + アイコン
cask "font-noto-sans-jp"             # 日本語フォント
